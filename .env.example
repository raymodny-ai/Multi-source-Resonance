# ============================================================
# Multi-source Resonance V2.0 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# ==================== 数据源 API 配置 ====================

# Tradier API (期权链与市场数据)
TRADIER_API_KEY=your_tradier_api_key_here
TRADIER_ACCOUNT_ID=your_account_id
TRADIER_SANDBOX_MODE=false
TRADIER_SANDBOX_TOKEN=

# SqueezeMetrics API (DIX/GEX 指标)
SQUEEZEMETRICS_API_KEY=your_squeezemetrics_key_here

# CCData API (CEX 衍生品数据, Free Tier: 10万次/月)
CCDATA_API_KEY=your_ccdata_key_here

# Coinglass API (已弃用, 保留兼容)
COINGLASS_API_KEY=

# ==================== LLM 推理配置 (V2.0 Layer 3) ====================

# Provider 选择: openai / anthropic
LLM_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_ORGANIZATION=
OPENAI_BASE_URL=

# Anthropic 配置
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=

# LLM 通用参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# ==================== 通知配置 ====================

# SMTP 邮件
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# Telegram Bot (可选)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook (可选)
DISCORD_WEBHOOK_URL=

# ==================== 系统配置 ====================

# 数据库路径
DATABASE_PATH=./database/monitoring.db

# 日志级别: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# 日志目录
LOG_DIR=./logs

# ==================== 管道配置 (V2.0) ====================

# 流水线报告输出目录
PIPELINE_OUTPUT_DIR=./reports

# 回测历史天数
PIPELINE_HISTORY_DAYS=90

# 并行工作数
PIPELINE_PARALLEL_WORKERS=4
