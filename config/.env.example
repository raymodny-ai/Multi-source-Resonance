# Tradier API Configuration
# 生产模式: 真实账户API密钥 (实时数据)
TRADIER_API_KEY=your_tradier_api_key_here
TRADIER_ACCOUNT_ID=your_account_id
# 沙箱模式: 免费注册Developer Sandbox (延迟15分钟数据)
# 注册地址: https://developer.tradier.com/user/sign_up
# 启用后将自动使用 https://sandbox.tradier.com/v1 端点
TRADIER_SANDBOX_MODE=false
TRADIER_SANDBOX_TOKEN=your_sandbox_token_here

# Hyperliquid DEX (去中心化衍生品, 完全免费, 无需API Key, 不屏蔽美国IP)
# 目前最大的衍生品DEX, 交易量全球前三, API完全开放
# 无需配置, 自动从 https://api.hyperliquid.xyz/info 获取

# CCData (原 CryptoCompare) Configuration (CEX衍生品, Free Tier 10万次/月)
# 注册: https://developers.coindesk.com/
# 老牌加密数据商, Funding Rate / OI / Liquidation 全覆盖
CCDATA_API_KEY=your_ccdata_api_key_here

# Coinglass API Configuration (已弃用, 保留兼容)
# 原用于全网加密衍生品聚合, 已替换为 Hyperliquid + CCData 降级链路
COINGLASS_API_KEY=your_coinglass_api_key_here

# FMP (Financial Modeling Prep) Configuration (结构化短卖JSON API, 250 req/day免费)
# 注册: https://site.financialmodelingprep.com/register
# 优势: JSON直出shortVolume/totalVolume, 省去FINRA管道文件解析
# Free Tier 250 req/day, Starter $19/月, Growth $49/月
FMP_API_KEY=your_fmp_api_key_here

# SqueezeMetrics Configuration
SQUEEZEMETRICS_API_KEY=your_squeezemetrics_key

# Notification Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Discord Webhook (Optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# System Configuration
DATABASE_PATH=./database/monitoring.db
LOG_LEVEL=INFO
